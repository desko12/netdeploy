<!-- WAN L3VPN - Multi-Site -->

<!-- Site Paris - PE Router -->
<config target="PE-Paris" host="10.0.1.1" os="ios" user="admin" password="wan-vpn123">
  <interface name="GigabitEthernet0/0">
    <description>WAN -连接到SP</description>
    <ip>10.0.1.1</ip>
    <mask>255.255.255.252</mask>
  </interface>
  
  <interface name="Loopback0">
    <description>Router ID</description>
    <ip>1.1.1.1</ip>
    <mask>255.255.255.255</mask>
  </interface>
  
  <bgp as="65101">
    <router-id>1.1.1.1</router-id>
    <neighbor ip="10.0.1.2" remote-as="65000">
      <description>ISP Route Reflector</description>
    </neighbor>
  </bgp>
</config>

